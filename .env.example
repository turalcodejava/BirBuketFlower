# Mailpit lokal SMTP (`docker compose up mailpit`) — UI http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_STARTTLS_ENABLE=false
MAIL_STARTTLS_REQUIRED=false
MAIL_USERNAME=local@birbuket.dev
MAIL_PASSWORD=unused
# Əlavə SMTP self-test (plantdoctor): PLANTDOCTOR_MAIL_PROBE_ENDPOINT=true → POST localhost:8085/api/plantdoctor/internal/mail-probe?to=test@example.com
# PLANTDOCTOR_MAIL_PROBE_ENDPOINT=false
MAIL_KAFKA_GROUP_ID=birbuket-mail-v3
PLANTDOCTOR_MAIL_FROM=local@birbuket.dev
# Boş: plantdoctor + mail-service həqiqi To ünvanına göndərir. Yalnız bütün məktubları tək ünvanda görmək üçün: MAIL_OVERRIDE_TO=sizin@test.com
MAIL_OVERRIDE_TO=

FRONTEND_RESET_BASE_URL=http://localhost:3000/reset-password

